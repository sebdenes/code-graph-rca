{
  "name": "code-graph-rca",
  "version": "1.0.1",
  "description": "RCA infrastructure for AI-built code. Code knowledge graph + opinionated RCA engine, exposed via MCP (Cursor / Claude Code / Cody / Cline / Continue / Windsurf / Zed) plus CLI and library. RCA is the wedge; the same engine covers code review, refactor blast-radius, and grounding for any agent's structural claims.",
  "type": "module",
  "license": "MIT",
  "author": "Sebastien Denes",
  "homepage": "https://github.com/sebdenes/code-graph-rca#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebdenes/code-graph-rca.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sebdenes/code-graph-rca/issues"
  },
  "keywords": [
    "rca",
    "root-cause-analysis",
    "code-graph",
    "knowledge-graph",
    "mcp",
    "model-context-protocol",
    "tree-sitter",
    "ai-agent",
    "claude-code",
    "cursor",
    "static-analysis",
    "call-graph",
    "typescript",
    "python"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cgrca": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "better-sqlite3": "^12.9.0",
    "ignore": "^7.0.5",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
