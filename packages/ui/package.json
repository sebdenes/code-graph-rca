{
  "name": "code-graph-rca-ui",
  "version": "0.0.1",
  "description": "Web UI for code-graph-rca: visualize the failure graph and downstream impact.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cgrca-view": "./dist/server/src/cli.js"
  },
  "main": "./dist/server/src/index.js",
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "vite build -c web/vite.config.ts",
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/src/cli.ts --dev",
    "dev:web": "vite -c web/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "code-graph-rca": "*",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "fastify": "^5.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cytoscape": "^3.30.2",
    "cytoscape-cose-bilkent": "^4.1.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.62.0",
    "@types/cytoscape": "^3.21.7",
    "monaco-editor": "^0.52.0",
    "@monaco-editor/react": "^4.6.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2",
    "zustand": "^5.0.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.0"
  }
}
