{
  "name": "code-graph-rca-github-app",
  "version": "0.4.4",
  "description": "GitHub PR-review for code-graph-rca — works as a GitHub App (hosted webhook) OR as a GitHub Action (no hosting). Posts ranked causal candidates + blast-radius comments on every PR.",
  "type": "module",
  "license": "MIT",
  "author": "Sebastien Denes",
  "keywords": [
    "github-action",
    "github-app",
    "pull-request",
    "code-review",
    "rca",
    "code-graph",
    "ai-agent"
  ],
  "homepage": "https://github.com/sebdenes/code-graph-rca#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebdenes/code-graph-rca.git",
    "directory": "packages/github-app"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cgrca-github-app": "./dist/cli.js",
    "cgrca-pr-review": "./dist/action-cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "code-graph-rca": "^0.4.4",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
